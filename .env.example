# Copy to .env and fill in. All values are optional; sensible defaults apply.

# --- Google Sheets roster ---
# Spreadsheet ID (the long string in the sheet URL between /d/ and /edit).
GOOGLE_SHEETS_ID=
# Numeric gid of the tab (the gid=... in the sheet URL). Used for the public
# CSV export path when no service account is configured.
GOOGLE_SHEETS_GID=0
# Worksheet/tab name (leave blank to use the first tab). Service-account only.
GOOGLE_SHEETS_TAB=
# Path to the Google service-account JSON key file. If absent and the sheet is
# link-shared, the app falls back to the public CSV export URL automatically.
GOOGLE_SA_JSON=service_account.json

# Header text marking each agent-name column in the roster's top block.
ROSTER_NAME_HEADER=Agent Name

# --- Timezones ---
# Single timezone the whole team works in.
APP_TZ=Asia/Kolkata
# Timezone the Zendesk Explore export timestamps are in (UTC is common).
EXPORT_TZ=UTC

# --- Attendance rules ---
GRACE_MIN=10
# Agents mark offline this many minutes before shift end; coverage is measured
# against [start, end - this], so leaving on time counts as full coverage.
SHIFT_END_BUFFER_MIN=15
UNDER_HOURS_THRESHOLD=0.85
PRESENT_STATES=online,away
